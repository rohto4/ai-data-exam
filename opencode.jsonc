{
  "$schema": "https://opencode.ai/config.json",

  "plugin": ["oh-my-openagent@latest"],

  // OpenCode Desktop の接続済みプロバイダー設定を使う。
  // このPJでは provider / enabled_providers / disabled_providers を定義しない。
  "model": "chutes/qwen3-32b-tee",
  "small_model": "openai/gpt-5.4-nano",

  // 長いセッションでコンテキスト溢れを防ぐ
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  }
}
