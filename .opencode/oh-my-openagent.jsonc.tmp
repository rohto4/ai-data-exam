{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "default_run_agent": "hephaestus",
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [
      400,
      503,
      529
    ],
    "max_fallback_attempts": 1,
    "cooldown_seconds": 60,
    "timeout_seconds": 45,
    "notify_on_fallback": true
  },
  "background_task": {
    "defaultConcurrency": 1,
    "staleTimeoutMs": 420000,
    "providerConcurrency": {
      "chutes": 1
    }
  },
  "model_capabilities": {
    "enabled": true,
    "auto_refresh_on_start": true,
    "refresh_timeout_ms": 5000,
    "source_url": "https://models.dev/api.json"
  },
  "hashline_edit": true,
  "agents": {
    "sisyphus": {
      "model": "openai/gpt-5.4",
      "fallback_models": [
        "chutes/qwen3-coder-next-tee"
      ]
    },
    "hephaestus": {
      "model": "openai/gpt-5.4",
      "fallback_models": [
        "chutes/qwen3-coder-next-tee"
      ]
    },
    "prometheus": {
      "model": "openai/gpt-5.4",
      "fallback_models": [
        "chutes/deepseek-r1-0528-tee"
      ],
      "prompt_append": "Always propose a verifiable plan (files, commands, success criteria)."
    },
    "oracle": {
      "model": "chutes/qwen3-32b-tee",
      "fallback_models": [
        "chutes/deepseek-r1-0528-tee"
      ],
      "permission": {
        "edit": "deny"
      }
    },
    "explore": {
      "model": "chutes/gemma-3-4b"
    },
    "librarian": {
      "model": "chutes/qwen3-32b-tee",
      "fallback_models": [
        "chutes/qwen3-32b-tee"
      ]
    },
    "multimodal-looker": {
      "model": "chutes/kimi-k2.5-tee",
      "fallback_models": [
        "chutes/glm-4.6v",
        "chutes/qwen2-5-vl-32b"
      ]
    },
    "metis": {
      "model": "chutes/qwen3-32b-tee",
      "fallback_models": [
        "chutes/deepseek-r1-0528-tee"
      ],
      "permission": {
        "edit": "deny"
      }
    },
    "momus": {
      "model": "chutes/qwen3-32b-tee",
      "fallback_models": [
        "chutes/tng-r1t2-chimera-tee",
        "chutes/glm-4.7-tee"
      ],
      "permission": {
        "edit": "deny"
      }
    },
    "atlas": {
      "model": "openai/gpt-5.4",
      "fallback_models": [
        "chutes/kimi-k2.5-tee"
      ]
    }
  },
  "categories": {
    "quick": {
      "model": "chutes/gemma-3-4b",
      "description": "Single-file small changes / quick checks"
    },
    "unspecified-low": {
      "model": "chutes/gemma-3-4b",
      "description": "Low-effort tasks, short analysis"
    },
    "unspecified-high": {
      "model": "chutes/qwen3-32b-tee",
      "fallback_models": [
        "chutes/deepseek-v3.2-tee"
      ],
      "description": "High-effort implementation and debugging"
    },
    "deep": {
      "model": "chutes/qwen3-32b-tee",
      "fallback_models": [
        "chutes/deepseek-r1-0528-tee"
      ],
      "description": "Thorough investigation before acting"
    },
    "ultrabrain": {
      "model": "chutes/kimi-k2.5-tee",
      "fallback_models": [
        "chutes/qwen3-32b-tee"
      ],
      "description": "Hard architecture / debugging"
    },
    "writing": {
      "model": "chutes/qwen3-32b-tee",
      "fallback_models": [
        "chutes/kimi-k2.5-tee"
      ],
      "description": "Docs / proposals / summaries"
    },
    "visual-engineering": {
      "model": "chutes/kimi-k2.5-tee",
      "fallback_models": [
        "chutes/glm-4.6v",
        "chutes/qwen2-5-vl-32b"
      ],
      "description": "UI/UX / visual inspection"
    }
  },
  "_migrations": [
    "model-version:openai/gpt-5.3-codex->openai/gpt-5.4"
  ]
}
