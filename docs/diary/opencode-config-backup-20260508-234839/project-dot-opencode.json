          "id": "mimo-v2.5-pro",
          "name": "MiMo V2.5 Pro"
        },
        "mimo-v2.5": {
          "id": "mimo-v2.5",
          "name": "MiMo V2.5"
        },
        "mimo-v2-pro": {
          "id": "mimo-v2-pro",
          "name": "MiMo V2 Pro"
        },
        "mimo-v2-omni": {
          "id": "mimo-v2-omni",
          "name": "MiMo V2 Omni"
        },
        "mimo-v2-flash": {
          "id": "mimo-v2-flash",
          "name": "MiMo V2 Flash"
        }
      }
    }
  }
}
